// Stack = 0x4000, growing up
// LUI      a2, $msb(0x4000)
00004137
// ADDI     a2, a2, $lsb(0x4000)
// hex( (0x0 << 20) + (0x2 << 15) + (0x2 << 7) + (0b0010011) )
00010113

// Call 0x1000
// ra = 0x1000
000010b7
00008093
// JALR ra, ra, 0
// hex( (0x1 << 15) + (0x1 << 7) + (0b1100111) )
000080e7

